        let tipka = 0;
        while (~(tipka = 128)) {
            let tipka = Keyboard.keyPressed();
        }

        do Screen.clearScreen();
        return;
    }

    function void osvojioMilijun() {
        var char tipka;
        var int i,j;

        do Screen.clearScreen();
        do Screen.setColor(true);
        
        do Screen.drawRectangle(80, 60, 430, 180); 
        do Screen.setColor(false);
        do Screen.drawRectangle(82, 62, 428, 178); 
        do Screen.setColor(true);

        do myPrint.moveCursor(7, 25);
        do myPrint.printString("NEVJEROJATNO!!!");
        do myPrint.moveCursor(9, 18);
        do myPrint.printString("OSVOJILI STE 1.000.000 EURA!");
        do myPrint.moveCursor(11, 21);
        do myPrint.printString("POSTALI STE MILIJUNA@!");
        do myPrint.moveCursor(15, 16);
        do myPrint.printString("Pritisnite ENTER za kraj igre...");

        let tipka = 0;
        while (~(tipka = 128)){
            let i = Generator.randRange(508); 
            let j = Generator.randRange(252);

            do Screen.setColor(true);
            do Screen.drawRectangle(i, j, i + 2, j + 2);
            
            do Sys.wait(50);
            let tipka = Keyboard.keyPressed();
        }
        return;
    }

    function void osvjeziEkran(int odabrano) {
        do Screen.clearScreen();
        do Game.pokreniPitanje(odabrano);
        
        if (~Game.getvA()) { do Screen.setColor(false); do Screen.drawRectangle(30,170,185,204); do Screen.setColor(true); }
        if (~Game.getvB()) { do Screen.setColor(false); do Screen.drawRectangle(205,170,360,204); do Screen.setColor(true); }
        if (~Game.getvC()) { do Screen.setColor(false); do Screen.drawRectangle(30,213,185,247); do Screen.setColor(true); }
        if (~Game.getvD()) { do Screen.setColor(false); do Screen.drawRectangle(205,213,360,247); do Screen.setColor(true); }
        return;
}

    function void main()
    {
        var int k,ans,odabrano;
        var bool cekajOdgovor;

        do HomeScreen.HomeScreenMain();
        let k = 0;

        while(~(k=128))
        {
            if(time<32767){
                let time = time + 1;
            }
            else
            {
                let time = 0;
            }
            let k = Keyboard.keyPressed();
        }

        do Screen.clearScreen();
        do Main.initGame();
        do myPrint.init();
        do myPrint.initLineLength();
        do myPrint.initMap();
        do Game.init1();

        while(game) {
            do Screen.clearScreen();
            do Game.resetPitanje(); 

            if(~(brojPitanja=1)) {
                do Main.ucitajPitanje();
                do Main.tocanOdgovor();
            }
            
            do Generator.setSeed(time);
            let odabrano = Main.odaberiPitanje();
            do Game.pokreniPitanje(odabrano);

            let cekajOdgovor = true;
            while(cekajOdgovor) {
                let ponavljanje = 0;
                let ans = 0;
                while(ans = 0) {
                    let ans = Keyboard.keyPressed();
                    let time = time + 1;
                    if (time > 32766){ let time = 0; }
                }
                do Generator.setSeed(time);

                if ((ans = 69) | (ans = 101)) {
                    let cekajOdgovor = false;
                    let game = false;
                    let odustajanje = true;
                    do Main.odustao(); 
                } 
                else {
                    if (((ans=49) & Game.getjok1()) | ((ans=50) & Game.getjok2()) | ((ans=51) & Game.getjok3())) {
                        do Main.zoviJoker(ans, odabrano); 
                        let ponavljanje = 1;
                        do Main.osvjeziEkran(odabrano); 
                    } 
                    else {
                        if ((((ans=65)|(ans=97)) & Game.getvA()) | 
                            (((ans=66)|(ans=98)) & Game.getvB()) | 
                            (((ans=67)|(ans=99)) & Game.getvC()) | 
                            (((ans=68)|(ans=100)) & Game.getvD())) {
                            
                            do Main.provjeriOdgovor(odabrano, ans);
                            
                            if (brojPitanja = 16) {
                                let game = false;
                                let cekajOdgovor = false;
                                let odustajanje = true; 
                                do Main.osvojioMilijun();
                            } 
                            else{
                            if (game) {
                                let cekajOdgovor = false; 
                            } 
                            else{
                                let cekajOdgovor = false;
                            }
                        }
                        }
                    }
                }
                do Sys.wait(200); 
            }
        }
        if(~(odustajanje=true)){
            do Main.kriviOdgovor();
        }
        return;
    }
}