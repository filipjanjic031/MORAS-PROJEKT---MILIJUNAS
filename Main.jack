    function void kriviOdgovor() {
        var char tipka;
        var String s;

        do Screen.clearScreen();
        do Screen.setColor(true);
        do Screen.drawRectangle(80, 60, 430, 180);
        do Screen.setColor(false);
        do Screen.drawRectangle(82, 62, 428, 178);
        do Screen.setColor(true);

        do myPrint.moveCursor(8, 16);
        let s = "NA>ALOST, VA@ ODGOVOR JE NETO]AN!";
        do myPrint.printString(s);
        do s.dispose();

        do myPrint.moveCursor(11, 21);
        let s = "Odlazite kuci s: ";
        do myPrint.printString(s);
        do s.dispose();

        let s = Game.getOsigurani(brojPitanja);
        do myPrint.printString(s);
        do s.dispose();

        let s = " EUR";
        do myPrint.printString(s);
        do s.dispose();

        do myPrint.moveCursor(14, 19);
        let s = "Pritisnite ENTER za kraj...";
        do myPrint.printString(s);
        do s.dispose();

        let tipka = 0;
        while (~(tipka = 128)) {
            let tipka = Keyboard.keyPressed();
        }

        do Screen.clearScreen();
        return;
    }

