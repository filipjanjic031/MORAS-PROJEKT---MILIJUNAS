    function void tocanOdgovor() {
        var char tipka;
        var String s;

        do Screen.setColor(true);
        do Screen.drawRectangle(80, 60, 430, 180);
        do Screen.setColor(false);
        do Screen.drawRectangle(82, 62, 428, 178);
        do Screen.setColor(true);

        do myPrint.moveCursor(7, 22);
        let s = "VA@ ODGOVOR JE TO]AN!";
        do myPrint.printString(s);
        do s.dispose();

        do myPrint.moveCursor(10, 21);
        let s = "Osvojili ste: ";
        do myPrint.printString(s);
        do s.dispose();

        do myPrint.printString(Game.getNagrada());

        let s = " EUR";
        do myPrint.printString(s);
