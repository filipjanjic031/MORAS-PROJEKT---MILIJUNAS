    function void drawJoker5050(int startX, int startY, int blockSize) {
        var int row, col, i;
        var Array M; 

        let M = Array.new(105); 
        let i = 0;
        while (i < 105) {
            let M[i] = 0;
            let i = i + 1;
        }

        let M[0]=1; let M[1]=1; let M[2]=1;    
        let M[4]=1; let M[5]=1; let M[6]=1;    
        let M[14]=1; let M[15]=1; let M[16]=1; 
        let M[18]=1; let M[19]=1; let M[20]=1; 

        let M[21+0]=1;                         
        let M[21+4]=1; let M[21+6]=1;           
        let M[21+10]=1;                        
        let M[21+14]=1;                        
        let M[21+18]=1; let M[21+20]=1;        

        let M[42+0]=1; let M[42+1]=1; let M[42+2]=1; 
        let M[42+4]=1; let M[42+6]=1;                
        let M[42+14]=1; let M[42+15]=1; let M[42+16]=1; 
        let M[42+18]=1; let M[42+20]=1;              

        let M[63+2]=1;                         
        let M[63+4]=1; let M[63+6]=1;           
        let M[63+10]=1;                        
        let M[63+16]=1;                        
        let M[63+18]=1; let M[63+20]=1;        

        let M[84+0]=1; let M[84+1]=1; let M[84+2]=1; 
        let M[84+4]=1; let M[84+5]=1; let M[84+6]=1; 
        let M[84+14]=1; let M[84+15]=1; let M[84+16]=1; 
        let M[84+18]=1; let M[84+19]=1; let M[84+20]=1; 

        let row = 0;
        while (row < 5) {
            let col = 0;
            while (col < 21) {
                if (M[(row * 21) + col] = 1) {
                    do Screen.drawRectangle(
                        startX + (col * blockSize), startY + (row * blockSize),
                        startX + (col * blockSize) + blockSize, startY + (row * blockSize) + blockSize
                    );
                }
                let col = col + 1;
            }
            let row = row + 1;
        }

        do M.dispose();
        return;
    }

    function void drawJokerPrijatelj(int startX, int startY, int blockSize) {
        var int row, col, i, radius;
        var Array M; 

        let M = Array.new(99); 
        let i = 0;
        while (i < 99) { let M[i] = 0; let i = i + 1; }

        let M[33+7]=1; let M[33+8]=1; 
        let M[44+6]=1; let M[44+7]=1; 
        let M[55+5]=1; let M[55+6]=1; 
        let M[66+4]=1; let M[66+5]=1; 
        let M[77+2]=1; let M[77+3]=1; 

        let row = 0;
        while (row < 9) {
            let col = 0;
            while (col < 11) {
                if (M[(row * 11) + col] = 1) {
                    do Screen.drawRectangle(
                        startX + (col * blockSize), 
                        startY + (row * blockSize),
                        startX + (col * blockSize) + blockSize, 
                        startY + (row * blockSize) + blockSize
                    );
                }
                let col = col + 1;
            }
            let row = row + 1;
        }

        let radius = blockSize * 2; 
        do Screen.drawCircle(startX + (10 * blockSize), startY + (1 * blockSize), radius);
        do Screen.drawCircle(startX + (1 * blockSize), startY + (8 * blockSize), radius);

        do M.dispose();
        return;
    }

    function void drawJokerPublika(int x, int y, int size) {
        do Screen.drawCircle(x, y, size);             
        do Screen.drawRectangle(x-size, y+size+1, x+size, y+(size*4)); 

        let x = x + (size * 4);
        do Screen.drawCircle(x, y, size);             
        do Screen.drawRectangle(x-size, y+size+1, x+size, y+(size*4));

        let x = x + (size * 4);
        do Screen.drawCircle(x, y, size);             
        do Screen.drawRectangle(x-size, y+size+1, x+size, y+(size*4));
        
        return;
    }

