    function void obrisiNizStringova(Array niz, int duljina) {
        var int i;
        var String s;
        let i = 0;
        while (i < duljina) {
            let s = niz[i];
            do s.dispose();
            let i = i + 1;
        }
        do niz.dispose();
        return;
    }

