        do Game.odgovorD(odgD);
        return;
    }

    function int getTocanOdg(int odabranoPitanje)
    {
        let tocanOdg = odabranoPitanje;
        while(~((tocanOdg-4)<0))
        {
            let tocanOdg = tocanOdg - 4;
        }
        return tocanOdg;
    }

    function void drawJokeri()
    {
        if(jok1=true){
            do Screen.drawRectangle(30,50,138,54);
            do Screen.drawRectangle(30,50,34,80);
            do Screen.drawRectangle(138,50,142,80);
            do Screen.drawRectangle(248,50,252,80);
            do myPrint.moveCursor(5, 6);
            do myPrint.printString("1");
            do Game.drawJoker5050(65,65,2);
        }    
        if(jok2=true){
            do Screen.drawRectangle(138,50,248,54);
            do Screen.drawRectangle(138,50,142,80);
            do Screen.drawRectangle(248,50,252,80);
            do myPrint.moveCursor(5, 20);
            do myPrint.printString("2");
            do Game.drawJokerPublika(183,65,3);

        }
        if(jok3=true)
        {
            do Screen.drawRectangle(248,50,360,54);
            do Screen.drawRectangle(356,50,360,80);
            do Screen.drawRectangle(138,50,142,80);
            do Screen.drawRectangle(248,50,252,80);
            do myPrint.moveCursor(5, 33);
            do myPrint.printString("3");
            do Game.drawJokerPrijatelj(292,58,2);
        }
        if((jok1=false) & (jok2=false))
        {
            do Screen.setColor(false);
            do Screen.drawRectangle(138,50,142,80);
            do Screen.setColor(true);
        }
        if((jok2=false) & (jok3=false))
        {
            do Screen.setColor(false);
            do Screen.drawRectangle(248,50,252,80);
            do Screen.setColor(true);
        }
        return;
    }

    function void pokreniPitanje(int odabrano)
    {
        do Game.GoreLijevo();
        do Game.drawJokeri();
        do Game.CrtanjePitanjaOdgovora(odabrano);
        return;
    }
}