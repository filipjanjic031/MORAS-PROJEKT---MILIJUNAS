                do myPrint.printChar(pitanje.charAt(j));
                let j = j + 1;
            }
        } 
        else
        {   do myPrint.moveCursor(9, 6);
                while (j<len){
                    if ((len-j)<38){
                        while (j<len){
                            do myPrint.printChar(pitanje.charAt(j));
                            let j = j + 1;
                        }
                    } 
                    else {
                        let t = j;
                        let posljednjiRazmak = j; 
                        while (t<(j + 38)){
                            if (pitanje.charAt(t) = 32) {
                                let posljednjiRazmak = t;
                            }
                            let t = t + 1;
                        }
                        while (j<posljednjiRazmak){
