    function String getOsigurani(int brojPitanja) {
        var String o1,o2,o3;

        let o1 = "0";
        let o2 = "1 000";
        let o3 = "32 000";
        if(brojPitanja<6)
        {
            return o1;
        }
        else
        {
            if(brojPitanja<11)
            {
                return o2;
            }
            else
            {
                return o3;
            }
        }
    }

    function void GoreLijevo()
    {
        do myPrint.moveCursor(0,0);
        do myPrint.printString("Broj pitanja: ");
        do myPrint.printInt(brojPitanja);
        do myPrint.println();
        do myPrint.printString("Osigurani iznos: ");
        do myPrint.printString(Game.getOsigurani(brojPitanja));
        do myPrint.printString("e");
        do Screen.drawRectangle(0,28,195,30);
        do Screen.drawRectangle(195,0,197,30);
        return;
    }

    function void odgovorA(String odgovor)
    {
        var int i,j,z,t,posljednjiRazmak,len;

        let i = 0;
        let j = 0;
        let z = 0;
        let t = 0;
        let posljednjiRazmak = 0;
        let len = odgovor.length();

        do myPrint.moveCursor(16, 6);
        do myPrint.printString("A ");
        while (j < len){
            if ((len - j)<15){
                while (j<len){
                    do myPrint.printChar(odgovor.charAt(j));
                    let j = j + 1;
                }
            } 
            else {
                let t = j;
                let posljednjiRazmak = j; 
                while (t<(j + 15)){
                    if (odgovor.charAt(t) = 32) {
                        let posljednjiRazmak = t;
                    }
                    let t = t + 1;
                }
                while (j<posljednjiRazmak){
                    do myPrint.printChar(odgovor.charAt(j));
                    let j = j + 1;
                }
                let z = z + 1;
                do myPrint.moveCursor(16 + z, 8);
                if (odgovor.charAt(j) = 32){
                    let j = j + 1;
                }
            }
        }
        return;
    }
    function void odgovorB(String odgovor)
    {
        var int i,j,z,t,posljednjiRazmak,len;

        let i = 0;
        let j = 0;
        let z = 0;
        let t = 0;
        let posljednjiRazmak = 0;
        let len = odgovor.length();

        do myPrint.moveCursor(16, 28);
        do myPrint.printString("B ");
        while (j < len){
            if ((len - j)<15){
                while (j<len){
                    do myPrint.printChar(odgovor.charAt(j));
                    let j = j + 1;
