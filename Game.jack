    function void odgovorOdustajem()
    {
        do myPrint.moveCursor(16, 49);
        do myPrint.printString("E Odustajem");
        do myPrint.moveCursor(19, 49);
        do myPrint.printString("IZNOS:");
        do myPrint.moveCursor(20, 49);
        do myPrint.printString(tablicaNagrada[brojPitanja-1]);
        do myPrint.printString("e");
        return;
    }

